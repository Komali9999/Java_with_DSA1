1.Tree traversal 
import java.util.*;

class Node {
    int data;
    Node left, right;

    public Node(int data) {
        this.data = data;
        this.left = this.right = null;
    }
}

class Tree {
    Node root;

    public Tree() {
        this.root = null;
    }

    public void insert(int data) {
        if (root == null) {
            root = new Node(data);
            return;
        }

        Queue<Node> q = new LinkedList<>();
        q.offer(root);

        while (!q.isEmpty()) {
            Node cur = q.poll();

            if (cur.left != null) {
                q.offer(cur.left);
            } else {
                cur.left = new Node(data);
                return;
            }

            if (cur.right != null) {
                q.offer(cur.right);
            } else {
                cur.right = new Node(data);
                return;
            }
        }
    }

    public void levelOrder() {
        if (root == null)
            return;

        Queue<Node> q = new LinkedList<>();
        q.offer(root);

        while (!q.isEmpty()) {
            Node cur = q.poll();
            System.out.print(cur.data + " ");

            if (cur.left != null)
                q.offer(cur.left);

            if (cur.right != null)
                q.offer(cur.right);
        }
    }
}

public class Main {
    public static void main(String[] args) {

        Tree t = new Tree();

        t.insert(10);
        t.insert(20);
        t.insert(30);
        t.insert(40);
        t.insert(50);
        t.insert(60);

        System.out.println("Level Order Traversal:");
        t.levelOrder();
    }
}
output:
Level order traversal
10 20 30 40 50 60
