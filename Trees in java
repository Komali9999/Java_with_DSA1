import java.util.*;

class Node {
    int data;
    Node left, right;

    public Node(int data) {
        this.data = data;
        this.left = this.right = null;
    }
}

class Tree {
    Node root;

    public Tree() {
        root = null;
    }

    
    public void insert(int data) {
        if (root == null) {
            root = new Node(data);
            return;
        }

        Queue<Node> q = new LinkedList<>();
        q.offer(root);

        while (!q.isEmpty()) {
            Node cur = q.poll();

            if (cur.left == null) {
                cur.left = new Node(data);
                return;
            } else {
                q.offer(cur.left);
            }

            if (cur.right == null) {
                cur.right = new Node(data);
                return;
            } else {
                q.offer(cur.right);
            }
        }
    }

   
    public void preOrder() {
        preOrderHelper(root);
    }

