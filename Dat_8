1.Given two sorted arrays, merge them into a single sorted array:
public class main {

    private static int[] merge(int[] a1, int[] a2) {
        int a1_size = a1.length;
        int a2_size = a2.length;

        int[] result = new int[a1_size + a2_size];

        int i = 0, j = 0, k = 0;

        while (i < a1_size && j < a2_size) {
            if (a1[i] <= a2[j]) {
                result[k++] = a1[i++];
            } else {
                result[k++] = a2[j++];
            }
        }

        while (i < a1_size) {
            result[k++] = a1[i++];
        }

        while (j < a2_size) {
            result[k++] = a2[j++];
        }

        return result;
    }

    public static void main(String[] args) {
        int[] M = {1, 3, 9};
        int[] N = {1, 5, 7};

        int[] sol = merge(M, N);

        for (int ele : sol) {
            System.out.print(ele + " ");
        }
    }
}
